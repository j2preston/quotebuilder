{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16",
    "paths": {
      "@quotebot/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    // ── Stale scaffolding — these reference removed packages (uuid,
    //    @azure/storage-blob, postgres, ioredis) and old shared types.
    //    They will be rewritten in subsequent tasks.
    "src/routes/quotes.ts",
    "src/routes/uploads.ts",
    "src/routes/webhooks/stripe.ts",
    "src/routes/webhooks/twilio.ts",
    "src/services/ai-extract.ts",
    "src/services/blob-storage.ts",
    "src/services/pdf.ts",
    "src/services/pricing.ts",
    "src/services/transcription.ts"
  ]
}
