{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16"
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    // ── Stale scaffolding — not yet rewritten; excluded until their task.
    "src/routes/uploads.ts",
    "src/routes/webhooks/stripe.ts",
    "src/routes/webhooks/twilio.ts",
    "src/services/ai-extract.ts",
    "src/services/blob-storage.ts",  // superseded by blobStorage.ts
    "src/services/pdf.ts",           // superseded by pdfGenerator.ts
    "src/services/pricing.ts",
    // test files are run directly via tsx, not compiled
    "src/**/*.test.ts"
  ]
}
